# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://evodeck:evodeck@localhost:5433/evodeck
AUTH_SECRET=change-me
DEFAULT_WORKSPACE_ID=

# AI provider switch: openai | gemini | vertex
AI_PROVIDER=openai

# --- openai (also OpenRouter / LM Studio / Ollama via base URL) ---
# Real key for OpenAI/OpenRouter. For local (LM Studio/Ollama) use any non-empty value, e.g. local
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- gemini (Google AI Studio API key — simplest Gemini path) ---
# AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- vertex (Gemini on Google Cloud / Vertex AI) ---
# AI_PROVIDER=vertex
# Put your Google Cloud API key here:
VERTEX_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Optional alias; falls back to GEMINI_MODEL
VERTEX_MODEL=gemini-2.5-flash
# If you skip VERTEX_API_KEY, use ADC instead:
#   gcloud auth application-default login
#   or GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Trigger.dev (run: npx trigger.dev@latest dev)
TRIGGER_SECRET_KEY=

# ClickHouse Cloud — live event store for generative desks
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=evodeck
