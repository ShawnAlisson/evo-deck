{
  "name": "evodeck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "openui:generate": "node scripts/generate-openui-assets.mjs",
    "dev": "next dev",
    "trigger:dev": "npx trigger.dev@latest dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clickhouse:init": "node --env-file=.env.local scripts/init-clickhouse.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clickhouse:events": "node --env-file=.env.local scripts/init-clickhouse-events.mjs",
    "db:migrate:sql": "docker exec -i evodeck-postgres psql -v ON_ERROR_STOP=1 -U evodeck -d evodeck < drizzle/0000_flowery_unicorn.sql && docker exec -i evodeck-postgres psql -v ON_ERROR_STOP=1 -U evodeck -d evodeck < drizzle/0001_collaborators.sql && docker exec -i evodeck-postgres psql -v ON_ERROR_STOP=1 -U evodeck -d evodeck < drizzle/0002_timeline_branches.sql"
  },
  "dependencies": {
    "@clickhouse/client": "^1.23.1",
    "@google/genai": "^2.12.0",
    "@openuidev/react-headless": "^0.9.2",
    "@openuidev/react-lang": "^0.2.8",
    "@openuidev/react-ui": "^0.12.1",
    "@trigger.dev/sdk": "^4.5.4",
    "ai": "^7.0.30",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "openai": "^6.48.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@trigger.dev/build": "^4.5.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
